{:source-paths ["src" "test" "dev" "resources"]

 :dependencies
 [[reagent "2.0.0"]
  [re-frame "1.4.3"]]

 :dev-http {3000 "public"}

 :builds
 {:dev
  {:target :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules {:main {:init-fn cartoj.demo/init}}}

  :test
  {:target :node-test
   :output-to "target/test/test.js"
   :ns-regexp "-test$"}

  :bench
  {:target :node-script
   :output-to "target/bench/bench.js"
   :main cartoj.bench/main}}}
