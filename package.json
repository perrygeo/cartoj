{
  "name": "cartoj",
  "version": "0.1.0",
  "description": "ClojureScript / Reagent wrapper around react-map-gl (MapLibre)",
  "private": true,
  "scripts": {
    "dev": "shadow-cljs watch dev",
    "test": "shadow-cljs compile test && node target/test/test.js",
    "test:coverage": "shadow-cljs compile test && node scripts/fix-source-maps.js && c8 node target/test/test.js",
    "bench": "shadow-cljs release bench && node target/bench/bench.js",
    "build": "shadow-cljs release lib"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.4.3",
    "@maplibre/maplibre-gl-geocoder": "^1.7.0",
    "maplibre-gl": "^5.0.0",
    "pmtiles": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "shadow-cljs": "^2.28.0"
  }
}
